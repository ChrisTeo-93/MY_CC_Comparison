{
  "name": "my_cc_comparison",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "mobile"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "npm run typecheck && npm run typecheck --workspace=@kadcompare/core && npm run typecheck --workspace=@kadcompare/mobile",
    "mobile": "npm run start --workspace=@kadcompare/mobile"
  },
  "dependencies": {
    "@kadcompare/core": "*",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.6",
    "typescript": "5.5.3",
    "vitest": "2.0.3"
  }
}
